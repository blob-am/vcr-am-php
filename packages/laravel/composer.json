{
    "name": "blob-solutions/laravel-vcr-am",
    "description": "Official Laravel adapter for the VCR.AM Virtual Cash Register PHP SDK — ServiceProvider, Facade, config publishing, and Artisan commands.",
    "type": "library",
    "license": "ISC",
    "keywords": [
        "vcr",
        "vcr-am",
        "armenia",
        "armenian",
        "cash-register",
        "virtual-cash-register",
        "fiscalization",
        "src",
        "tax-service",
        "e-receipt",
        "fiscal",
        "blob-solutions",
        "php",
        "laravel",
        "laravel-package"
    ],
    "homepage": "https://vcr.am",
    "support": {
        "issues": "https://github.com/blob-am/vcr-am-php/issues",
        "source": "https://github.com/blob-am/laravel-vcr-am"
    },
    "authors": [
        {
            "name": "Alex Kraiz",
            "email": "support@blob.am",
            "homepage": "https://blob.am",
            "role": "Maintainer"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "blob-solutions/vcr-am-sdk": "^0.1 || dev-main",
        "illuminate/console": "^11.0 || ^12.0 || ^13.0",
        "illuminate/contracts": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "spatie/laravel-package-tools": "^1.93"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.29",
        "nyholm/psr7": "^1.8",
        "orchestra/testbench": "^9.0 || ^10.0",
        "pestphp/pest": "^3.7",
        "pestphp/pest-plugin-laravel": "^3.0",
        "pestphp/pest-plugin-type-coverage": "^3.5",
        "php-http/mock-client": "^1.6",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "BlobSolutions\\LaravelVcrAm\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BlobSolutions\\LaravelVcrAm\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "BlobSolutions\\LaravelVcrAm\\VcrAmServiceProvider"
            ],
            "aliases": {
                "VcrAm": "BlobSolutions\\LaravelVcrAm\\Facades\\VcrAm"
            }
        },
        "branch-alias": {
            "dev-main": "0.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../sdk",
            "options": {
                "symlink": true
            }
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "pest --colors=always",
        "test:coverage": "pest --coverage --min=100 --colors=always",
        "test:type-coverage": "pest --type-coverage --min=100 --colors=always",
        "phpstan": "phpstan analyse --no-progress --memory-limit=1G",
        "format": "pint",
        "format:check": "pint --test",
        "check": [
            "@format:check",
            "@phpstan",
            "@test"
        ]
    },
    "scripts-descriptions": {
        "test": "Run Pest test suite",
        "test:coverage": "Run tests with line coverage report (enforces 100%; requires xdebug or pcov locally)",
        "test:type-coverage": "Run Pest type coverage check (must be 100%)",
        "phpstan": "Run static analysis at level max + strict + Larastan extension",
        "format": "Apply Pint code style fixes",
        "format:check": "Verify code style without writing changes",
        "check": "Run the full local CI pipeline (format + phpstan + test)"
    }
}
